        <!-- ViT-B/32 -->
        <mxCell id="vit_box" value="&lt;b&gt;RemoteCLIP ViT-B/32&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="245" width="280" height="45" as="geometry" />
        </mxCell>

        <!-- LoRA box connected to ViT -->
