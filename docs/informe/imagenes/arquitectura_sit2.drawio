          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="400" y="430" as="sourcePoint" />
            <mxPoint x="400" y="470" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Projection -->
        <mxCell id="proj_box" value="&lt;b&gt;Projection Head&lt;/b&gt;&lt;br&gt;Linear(512, 256)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=0;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="425" width="240" height="50" as="geometry" />
        </mxCell>

