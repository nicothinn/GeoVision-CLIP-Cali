          <mxGeometry x="195" y="575" width="410" height="55" as="geometry" />
        </mxCell>

        <!-- ====== TRAINING INFO BOX (right side) ====== -->
        <mxCell id="train_title" value="&lt;b&gt;Entrenamiento&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="680" width="720" height="145" as="geometry" />
        </mxCell>

        <!-- Loss -->
        <mxCell id="loss_box" value="&lt;b&gt;Loss Total&lt;/b&gt;&lt;br&gt;CE(y,ŷ) + 0.1·SAE&lt;br&gt;Label smoothing = 0.1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="720" width="165" height="55" as="geometry" />
        </mxCell>

        <!-- Optimizer -->
        <mxCell id="opt_box" value="AdamW&lt;br&gt;lr=10⁻⁴, wd=10⁻⁶&lt;br&gt;Cosine LR scheduler&lt;br&gt;Warmup 5 epocas" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;arcSize=10;" vertex="1" parent="1">
