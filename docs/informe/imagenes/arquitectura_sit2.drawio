            <mxPoint x="400" y="200" as="sourcePoint" />
            <mxPoint x="400" y="250" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- conv1 adaptation -->
        <mxCell id="conv1_box" value="&lt;b&gt;conv1 adaptada&lt;/b&gt;&lt;br&gt;3 canales → 12 canales" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=0;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="290" y="170" width="220" height="50" as="geometry" />
